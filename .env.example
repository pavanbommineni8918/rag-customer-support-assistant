# ============================================================
#  RAG Customer Support Assistant — Environment Configuration
# ============================================================

# --- LLM Provider (choose one) ---
# Option 1: Groq (recommended — free tier available)
# Get your API key at: https://console.groq.com
GROQ_API_KEY=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
# Option 2: OpenAI (alternative)
# OPENAI_API_KEY=your_openai_api_key_here

# --- LLM Settings ---
LLM_PROVIDER=groq              # groq | openai | ollama
LLM_MODEL=llama3-8b-8192       # groq: llama3-8b-8192 | llama3-70b-8192
LLM_TEMPERATURE=0.1            # Low = more deterministic/factual

# --- Retrieval Settings ---
TOP_K_CHUNKS=4                 # Number of chunks to retrieve per query
SIMILARITY_THRESHOLD=0.7       # ChromaDB distance threshold (lower = stricter)
CHUNK_SIZE=500                 # Token size per chunk
CHUNK_OVERLAP=50               # Overlap between chunks

# --- Confidence Thresholds ---
CONFIDENCE_THRESHOLD=0.6       # Below this → escalate to HITL
HITL_TIMEOUT_SECONDS=60        # Seconds to wait for human response

# --- Paths ---
PDF_PATH=data/knowledge_base.pdf         # Path to your knowledge base PDF
CHROMA_PERSIST_DIR=./chroma_db           # ChromaDB persistence directory
ESCALATION_LOG=logs/escalation_log.json  # Escalation log file

# --- Embedding Model ---
EMBEDDING_MODEL=all-MiniLM-L6-v2        # HuggingFace sentence-transformer model

# --- Collection ---
CHROMA_COLLECTION=rag_support_kb         # ChromaDB collection name
